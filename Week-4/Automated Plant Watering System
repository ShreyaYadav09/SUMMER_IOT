#include <ESP8266WiFi.h>
#include <LiquidCrystal_I2C.h>
#include <Wire.h>

LiquidCrystal_I2C lcd(0x27,16,2);

#define SOIL_PIN A0
#define LDR_PIN D5
#define RELAY_PIN D6
#define BUTTON_PIN D7

const char* ssid="YOUR_WIFI";
const char* password="YOUR_PASSWORD";

unsigned long lastRead=0;
unsigned long lastWater=0;
unsigned long manualLock=0;

const unsigned long interval=1800000;      //30 min
const unsigned long lockTime=300000;       //5 min

void setup(){

Serial.begin(115200);

pinMode(LDR_PIN,INPUT);
pinMode(RELAY_PIN,OUTPUT);
pinMode(BUTTON_PIN,INPUT_PULLUP);

digitalWrite(RELAY_PIN,LOW);

lcd.init();
lcd.backlight();

WiFi.begin(ssid,password);

while(WiFi.status()!=WL_CONNECTED){
delay(500);
Serial.print(".");
}

Serial.println("WiFi Connected");
}

void loop(){

unsigned long now=millis();

if(digitalRead(BUTTON_PIN)==LOW){

if(now>manualLock){

waterPlant();

manualLock=now+lockTime;

}

}

if(now-lastRead>=interval){

lastRead=now;

checkSoil();

}

}

void checkSoil(){

int soil=analogRead(SOIL_PIN);

int moisture=map(soil,1023,0,0,100);

bool overcast=digitalRead(LDR_PIN)==LOW;

lcd.clear();

lcd.setCursor(0,0);
lcd.print("Moist:");
lcd.print(moisture);
lcd.print("%");

lcd.setCursor(0,1);

if(moisture<30){

lcd.print("DRY");

if(!overcast){

waterPlant();

}

else{

lcd.print(" Rain Mode");

}

}

else if(moisture<70){

lcd.print("OPTIMAL");

}

else{

lcd.print("WET");

}

Serial.print("Moisture=");
Serial.print(moisture);
Serial.println("%");

sendGoogleSheet(moisture);

}

void waterPlant(){

digitalWrite(RELAY_PIN,HIGH);

lcd.clear();
lcd.print("Watering...");

Serial.println("Pump ON");

delay(5000);

digitalWrite(RELAY_PIN,LOW);

lastWater=millis();

Serial.println("Pump OFF");

}

void sendGoogleSheet(int moisture){

Serial.println("Sending Data to Google Sheets");

}

