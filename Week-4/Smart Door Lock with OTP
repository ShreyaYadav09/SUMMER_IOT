#include <Keypad.h>
#include <LiquidCrystal_I2C.h>
#include <ESP32Servo.h>
#include "BluetoothSerial.h"

LiquidCrystal_I2C lcd(0x27,16,2);

BluetoothSerial SerialBT;

Servo doorServo;


char keys[4][4] = {

{'1','2','3','A'},
{'4','5','6','B'},
{'7','8','9','C'},
{'*','0','#','D'}

};


byte rowPins[4]={13,12,14,27};
byte colPins[4]={26,25,33,32};


Keypad keypad = Keypad(
makeKeymap(keys),
rowPins,
colPins,
4,
4);



#define SERVO_PIN 18



String correctID="1234";

String generatedOTP="";

unsigned long otpStart;

bool otpGenerated=false;


void setup(){

Serial.begin(115200);

SerialBT.begin("ESP32_DOOR_LOCK");


lcd.init();
lcd.backlight();


doorServo.attach(SERVO_PIN);

doorServo.write(0);


lcd.print("Smart Door Lock");

delay(2000);

lcd.clear();

}



void loop(){


lcd.setCursor(0,0);
lcd.print("Enter ID:");

String id="";


while(id.length()<4){

char key=keypad.getKey();

if(key){

id+=key;

lcd.setCursor(id.length(),1);
lcd.print("*");

}

}



if(id==correctID){


generateOTP();


}
else{


Serial.println("ACCESS FAILED");

lcd.clear();
lcd.print("Wrong ID");

delay(2000);

}


delay(500);

}



void generateOTP(){


generatedOTP="";


for(int i=0;i<6;i++){

generatedOTP += random(0,10);

}


Serial.print("OTP Generated:");
Serial.println(generatedOTP);


SerialBT.print("Your OTP: ");
SerialBT.println(generatedOTP);


otpStart=millis();

otpGenerated=true;


lcd.clear();
lcd.print("OTP Sent");

delay(2000);


enterOTP();

}



void enterOTP(){


String entered="";


lcd.clear();
lcd.print("Enter OTP:");



while(millis()-otpStart < 30000){


char key=keypad.getKey();


if(key){


entered+=key;


lcd.setCursor(entered.length(),1);
lcd.print("*");



if(entered.length()==6){


if(entered==generatedOTP){


unlockDoor();

}

else{


Serial.println("OTP FAILED");

lcd.clear();
lcd.print("Invalid OTP");

delay(2000);

}

return;


}

}


}



lcd.clear();

lcd.print("OTP Expired");


Serial.println("OTP TIMEOUT");


delay(2000);

}


void unlockDoor(){


Serial.println("ACCESS GRANTED");


lcd.clear();

lcd.print("Door Opening");


doorServo.write(90);


delay(5000);


doorServo.write(0);


lcd.clear();

lcd.print("Door Locked");


}
